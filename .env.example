# Telegram bot token from @BotFather
TG_TOKEN=

# Navidrome credentials (Subsonic API)
NAVIDROME_URL=http://localhost:4533
NAVIDROME_USER=
NAVIDROME_PASS=

# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USERS=

# Path to music library (default: /music)
MUSIC_DIR=/music

# MP3 bitrate for inline playback (default: 320)
STREAM_BITRATE=320

# --- Optional ---

# Public Navidrome URL for share links (disabled if not set)
#NAVIDROME_PUBLIC_URL=https://music.example.com

# Download quality: LOSSLESS (16-bit FLAC) or HI_RES_LOSSLESS (24-bit M4A)
#QUALITY=LOSSLESS

# Set to false to skip writing metadata tags
#WRITE_TAGS=true

# Proxy (if Tidal CDN is blocked in your region)
#HTTP_PROXY=http://your-proxy:1080
#HTTPS_PROXY=http://your-proxy:1080
#NO_PROXY=localhost,127.0.0.1,192.168.1.0/24,host.docker.internal
