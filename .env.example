# Telegram bot token from @BotFather
TG_TOKEN=

# Navidrome credentials (Subsonic API)
NAVIDROME_URL=http://localhost:4533
NAVIDROME_USER=
NAVIDROME_PASS=

# Comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USERS=

# Host path holding the music library AND the staging dir (.slskd-downloads/).
# Both must be on the same filesystem so the post-download import is an
# atomic rename — cross-volume turns it into copy+delete and breaks scanner
# safety. Default /media/music.
MUSIC_LIBRARY_DIR=/media/music

# Soulseek (slskd) credentials — register at slsknet.org if you don't have them
SOULSEEK_USERNAME=
SOULSEEK_PASSWORD=

# Soulseek peer port — must match an inbound port forward on your router for
# remote peers to reach you. Default 50300 (slskd's standard).
SLSKD_LISTEN_PORT=50300

# MP3 bitrate Navidrome transcodes to for inline playback (default: 320)
#STREAM_BITRATE=320

# --- Optional ---

# Public Navidrome URL for share links (disabled if not set)
#NAVIDROME_PUBLIC_URL=https://music.example.com

# Soulseek peer quality cap. Defaults: 24-bit / 96 kHz / 2 GiB per file.
# Set 16 / 44100 for redbook-only. MAX_FILE_BYTES=0 disables the size cap.
#MAX_BIT_DEPTH=24
#MAX_SAMPLE_RATE_HZ=96000
#MAX_FILE_BYTES=2147483648

# Last.fm API key. Optional — when set, community tags ("witch house",
# "chillwave", etc.) get merged into Deezer's coarser album genres. Free
# registration at https://www.last.fm/api/account/create.
#LASTFM_API_KEY=

# Outbound proxy. All HTTP sessions are configured with trust_env=True so
# they pick up HTTP_PROXY / HTTPS_PROXY / NO_PROXY. If a specific upstream
# throttles your proxy IP (Odesli, Deezer, lrclib are common offenders),
# add its host to NO_PROXY so that one endpoint goes direct.
#HTTP_PROXY=http://your-proxy:1080
#HTTPS_PROXY=http://your-proxy:1080
#NO_PROXY=localhost,127.0.0.1,host.docker.internal,slskd
